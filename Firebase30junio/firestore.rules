rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cada estudiante solo puede leer y escribir su propio documento
    // en la colección "users" (el id del documento = su uid de Firebase Auth).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
